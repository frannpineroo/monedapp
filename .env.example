POSTGRES_DB=monedapp
POSTGRES_USER=monedapp_user
POSTGRES_PASSWORD=monedapp_pass
# Local (host → container port 5433). Inside docker compose backend uses @db:5432.
DATABASE_URL=postgresql://monedapp_user:monedapp_pass@localhost:5433/monedapp
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=8000
