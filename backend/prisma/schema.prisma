generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  ARS
  USD
  USDT
}

enum AccountKind {
  ASSET
  INCOME
  EXPENSE
  EQUITY
}

enum MovementType {
  income
  expense
  transfer
}

enum ExchangeRateType {
  oficial
  blue
  mep
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  profileTemplate      String?
  monotributoCategory  String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts     Account[]
  wallets      Wallet[]
  clients      Client[]
  movements    Movement[]
  integrations Integration[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  kind      AccountKind
  currency  Currency?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet?
  ledgerEntries LedgerEntry[]

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  accountId String   @unique
  currency  Currency
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@index([userId])
  @@map("wallets")
}

model Client {
  id              String   @id @default(cuid())
  userId          String
  name            String
  defaultCurrency Currency @default(ARS)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@index([userId])
  @@map("clients")
}

model ExchangeRate {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  type      ExchangeRateType
  currency  Currency
  value     Decimal          @db.Decimal(18, 6)
  source    String
  createdAt DateTime         @default(now())

  movements Movement[]

  @@unique([date, type, currency])
  @@index([currency, date])
  @@map("exchange_rates")
}

model Movement {
  id             String       @id @default(cuid())
  userId         String
  walletId       String
  clientId       String?
  toWalletId     String?
  type           MovementType
  amount         Decimal      @db.Decimal(18, 2)
  currency       Currency
  exchangeRateId String
  description    String
  date           DateTime     @db.Date
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet        @relation(fields: [walletId], references: [id])
  client       Client?       @relation(fields: [clientId], references: [id])
  exchangeRate ExchangeRate  @relation(fields: [exchangeRateId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@index([walletId])
  @@index([clientId])
  @@index([date])
  @@map("movements")
}

model LedgerEntry {
  id         String   @id @default(cuid())
  movementId String
  accountId  String
  change     Decimal  @db.Decimal(18, 2)
  currency   Currency
  createdAt  DateTime @default(now())

  movement Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id])

  @@index([movementId])
  @@index([accountId])
  @@map("ledger_entries")
}

model Integration {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  credentials String
  status      String   @default("disconnected")
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}
